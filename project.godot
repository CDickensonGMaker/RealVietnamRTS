[layer_names]

3d_physics/layer_1="terrain"
3d_physics/layer_2="us_units"
3d_physics/layer_3="vc_units"
3d_physics/layer_4="nva_units"
3d_physics/layer_5="vehicles"
3d_physics/layer_6="helicopters"
3d_physics/layer_7="buildings"
3d_physics/layer_8="projectiles"

[rendering]

textures/default_filters/anisotropic_filtering_level=4
anti_aliasing/quality/msaa_3d=2
